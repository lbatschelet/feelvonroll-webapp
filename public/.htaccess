<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Plausible first-party proxy endpoints ---
  # These help avoid common adblock filter lists by serving Plausible under your domain.
  #
  # Requirements on the server:
  # - mod_rewrite enabled
  # - Proxying enabled (RewriteRule [P]) via mod_proxy + mod_proxy_http

  RewriteRule ^js/script\.js$ https://analytics.baets.ch/js/script.js [P,L]
  RewriteRule ^api/event$ https://analytics.baets.ch/api/event [P,L]

  # --- SPA fallback ---
  # If the requested file or directory exists, serve it directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, fall back to index.html (let the SPA handle routing).
  RewriteRule ^ index.html [L]
</IfModule>

# Routing support for static webapp deployment (Apache)
#
# Why:
# - iOS home screen shortcuts may drop query params.
# - We therefore support path-based routes like /kiosk/<station> and /station/<station>.
# - These routes must resolve to index.html so the app can parse window.location.pathname.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files/directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Keep /issue/ MPA entry stable.
  RewriteRule ^issue$ /issue/ [R=301,L]

  # Path-based station/kiosk routes (used especially for iOS home-screen mode).
  RewriteRule ^kiosk/[^/]+/?$ /index.html [L]
  RewriteRule ^station/[^/]+/?$ /index.html [L]
  # Short station route for QR codes: /s/<station>
  RewriteRule ^s/[^/]+/?$ /index.html [L]
</IfModule>
